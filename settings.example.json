{
  "hooks": {
    "UserPromptSubmit": [
      {
        "command": "node <PATH_TO_CONFIG>/hooks/check_log.js"
      }
    ],
    "PostToolUse": [
      {
        "command": "node <PATH_TO_CONFIG>/hooks/detect_significant_event.js"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "command": "node <PATH_TO_CONFIG>/hooks/check_hardcoded_paths.js"
      }
    ],
    "Stop": [
      {
        "command": "node <PATH_TO_CONFIG>/hooks/check_decision_prose.js"
      }
    ]
  }
}
